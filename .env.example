# ── mock-stock WebSocket simulator ───────────────────────────────────────────
# Run the simulator:  cargo run --release -- config/pipeline.toml
# The bridge reads from here.
WS_URL=ws://localhost:8080

# ── WebSocket → Kafka bridge (ws_to_kafka.py) ────────────────────────────────
RECONNECT_DELAY_S=5
MAX_RECONNECT_ATTEMPTS=0          # 0 = unlimited retries
LOG_INTERVAL_N=500                # log a line every N published events
SKIP_UNKNOWN_EVENTS=false         # set true to silently drop unmapped event_types

# Topic overrides (change to route events to different Kafka topic names)
TOPIC_TRADES=stock.trades
TOPIC_ORDERS=stock.orders
TOPIC_QUOTES=stock.quotes
TOPIC_ORDERBOOK=stock.orderbook
TOPIC_STATS=stock.stats
TOPIC_HALTS=stock.halts
TOPIC_AGENTS=stock.agents

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=dagster-stock-pipeline
KAFKA_AUTO_OFFSET_RESET=earliest

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local             # local | s3
LOCAL_DATA_DIR=./data

# ── MinIO / S3 (only needed when STORAGE_BACKEND=s3) ─────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
STORAGE_BUCKET=stock-lake

# ── DuckDB ────────────────────────────────────────────────────────────────────
DUCKDB_PATH=:memory:
DUCKDB_THREADS=4

# ── Dagster ───────────────────────────────────────────────────────────────────
DAGSTER_HOME=.dagster
RUST_LOG=info                     # logging level for mock-stock process
