{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.3.3"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Asset Materialisation Rate (per minute)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(dagster_asset_materializations_total[1m])",
          "legendFormat": "{{asset_key}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "Kafka Consumer Lag",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "kafka_consumer_group_lag_sum",
          "legendFormat": "{{topic}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "id": 3,
      "title": "Asset Check Pass Rate",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(dagster_asset_check_results_total{result=\"passed\"}) / sum(dagster_asset_check_results_total) * 100",
          "legendFormat": "Pass Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "green", "value": 95}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8}
    },
    {
      "id": 4,
      "title": "Pipeline Run Duration (seconds)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "dagster_run_duration_seconds",
          "legendFormat": "{{job_name}}"
        }
      ],
      "gridPos": {"h": 8, "w": 16, "x": 8, "y": 8}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["stock-pipeline", "dagster", "kafka"],
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "title": "Stock Pipeline Overview",
  "uid": "stock-pipeline-overview",
  "version": 1
}
